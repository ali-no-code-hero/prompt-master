# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: share links (`/share/...`) and background jobs (`after()` pipeline) bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# AI (server-only; never expose to the client)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional overrides
# Primary OpenAI path uses Responses API + web search; use a model that supports it (default gpt-4o).
OPENAI_PRIMARY_MODEL=gpt-4o
# Gemini primary enables Grounding with Google Search (`google_search` tool); see model list in Gemini docs.
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
EXTRACTION_MODEL=gpt-4o-mini
